{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stackgen Module Schema",
    "type": "object",
    "properties": {
      "version": {
        "type": "string"
      },
      "representation": {
        "type": "object",
        "properties": {
          "side_panel": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "icon": { "type": "string" }
            },
            "required": ["label"]
          },
          "node": {
            "type": "object",
            "properties": {
              "label": {
                "type": "object",
                "properties": {
                  "static": { "type": "string" },
                  "template": { "type": "string" }
                },
                "required": ["static"]
              },
              "display_type": { "type": "string", "enum": ["default", "connection", "container"] }
            },
            "required": ["label"]
          }
        },
        "required": ["side_panel", "node"]
      },
      "variables": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "description": { "type": ["string", "null"] },
            "ui_control": { "type": "string", "enum": ["select", "text", "json", "yaml","dictionary","dictionary_list","textarea","password","shell","markdown","text_list","textarea_list","object","object_list","hcl"] },
            "options": { "type": "array", "items": {} },
            "value_type": { "type": "string" },
            "type": { "type": "string" },
            "validation": {
              "type": "object",
              "properties": {
                "minLength": { "type": "integer" },
                "maxLength": { "type": "integer" },
                "Pattern": { "type": "string" },
                "minValue (only for number type)": { "type": "integer" },
                "maxValue": { "type": "integer" },
                "required": { "type": "boolean" },
                "constraints": { "type": "array", "items": { "type": "object" } }
              },
              "additionalProperties": true
            },
            "attributes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "ui_control": { "type": "string" },
                  "value_type": { "type": "string" },
                  "default_editor": { "type": "string" },
                  "label": { "type": "string" },
                  "type": { "type": "string" },
                  "description": { "type": "string" },
                  "options": { "type": "array", "items": {} },
                  "validation": { "type": "object" }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "variable_groups": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "description": { "type": "string" },
            "variables": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["label", "variables"]
        }
      },
      "connections": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "target": { "type": "string" },
            "label": { "type": "string" },
            "references": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "to": { "type": "string" },
                  "from": { "type": "string" },
                  "output": { "type": "string" },
                  "input": { "type": "string" },
                  "transform": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          },
          "required": ["source", "target", "label", "references"]
        }
      },
      "discovery": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "dnd_supported": { "type": "boolean" },
          "data_source": { "type": "string" },
          "references": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "object", "properties": { "from": { "type": "string" }, "output": { "type": "string" } }, "required": ["from", "output"] },
                { "type": "object", "properties": { "status": { "type": "object", "properties": { "from": { "type": "string" }, "output": { "type": "string" } }, "required": ["from", "output"] } } },
                { "type": "array", "items": { "type": "object", "properties": { "suffix": { "type": "object", "properties": { "from": { "type": "string" }, "output": { "type": "string" } }, "required": ["from", "output"] } } } },
                { "type": "array", "items": { "type": "object", "properties": { "from": { "type": "string" }, "output": { "type": "string" } } } }
              ]
            }
          }
        }
      }
    },
    "required": ["version"]
  }