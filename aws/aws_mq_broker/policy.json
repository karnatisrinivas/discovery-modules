{
  "Name": "aws_mq_broker",
  "Policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "Default",
        "Effect": "Allow",
        "Action": [
          "mq:DescribeBroker",
          "mq:ListBrokers"
        ],
        "Resource": [
          "${module.module_name.arn}"
        ]
      }
    ]
  }
}