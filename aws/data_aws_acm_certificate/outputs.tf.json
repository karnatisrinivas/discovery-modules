        },
        "id": {
            "description": "The unique identifier of the ACM certificate.",
            "value": "${data.aws_acm_certificate.this.id}"
        },
        "status": {
            "description": "The current status of the ACM certificate.",
            "value": "${data.aws_acm_certificate.this.status}"
        },
        "tags": {
            "description": "The tags associated with the ACM certificate.",
            "value": "${data.aws_acm_certificate.this.tags}"
