{
    "output": {
        "arn": {
            "description": "The Amazon Resource Name (ARN) of the ACM certificate.",
            "value": "${data.aws_acm_certificate.this.arn}"
        },
        "certificate": {
            "description": "The PEM-encoded certificate content.",
            "value": "${data.aws_acm_certificate.this.certificate}"
        },
        "certificate_chain": {
            "description": "The PEM-encoded certificate chain content.",
