{
    "Name": "aws_secretsmanager_secret",
    "Policy": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Sid": "Default",
                "Effect": "Allow",
                "Action": [
                    "secretsmanager:DescribeSecret",
                    "secretsmanager:GetSecretValue",
                    "secretsmanager:ListSecrets"
                ],
                "Resource": [
                    "${module.module_name.arn}"
                ]
            }
        ]
    }
}