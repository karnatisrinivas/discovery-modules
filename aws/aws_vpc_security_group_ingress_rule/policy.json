{
    "name": "aws_vpc_security_group_ingress_rule",
    "policy": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Sid": "Default",
                "Effect": "Allow",
                "Action": [
                    "ec2:AuthorizeSecurityGroupIngress"
                ],
                "Resource": [
                    "${module.module_name.arn}"
                ]
            }
        ]
    }
}