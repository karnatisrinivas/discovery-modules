[
    {
        "name": "Reader",
        "resource_type": "aws_eks_cluster_cluster",
        "description": "Read clusters and Node groups",
        "policy": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Effect": "Allow",
                    "Action": [
                        "eks:DescribeCluster",
                        "eks:ListClusters",
                        "eks:DescribeNodegroup",
                        "eks:ListNodegroups"
                    ],
                    "Resource": [
                        "${module.module_name.arn}"
                    ]
                }
            ]
        }
    },
    {
        "name": "Writer",
        "resource_type": "aws_eks_cluster_cluster",
        "description": "Create/Delete/Update clusters and node groups",
        "policy": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Effect": "Allow",
                    "Action": [
                        "eks:CreateCluster",
                        "eks:DeleteCluster",
                        "eks:UpdateClusterConfig",
                        "eks:UpdateClusterVersion",
                        "eks:CreateNodegroup",
                        "eks:DeleteNodegroup",
                        "eks:UpdateNodegroupConfig",
                        "eks:UpdateNodegroupVersion"
                    ],
                    "Resource": [
                        "${module.module_name.arn}"
                    ]
                }
            ]
        }
    },
    {
        "name": "Admin",
        "resource_type": "aws_eks_cluster",
        "description": "All actions allowed",
        "policy": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Effect": "Allow",
                    "Action": [
                        "eks:*"
                    ],
                    "Resource": [
                        "${module.module_name.arn}"
                    ]
                }
            ]
        }
    }
]